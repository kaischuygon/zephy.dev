---
import Layout from "../../layouts/Layout.astro";
import { getStatusInfo, noBodyStatuses, type StatusInfo } from "../../utils/statusInfo";

export function getStaticPaths() {
    return Array.from({ length: 500 }, (_, index) => {
        const code = 100 + index;
        return {
            params: { code: String(code) },
            props: { statusInfo: getStatusInfo(code) },
        };
    });
}

const { statusInfo } = Astro.props as { statusInfo: StatusInfo };

if (!noBodyStatuses.has(statusInfo.code)) {
    if (statusInfo.code >= 400) Astro.response.status = statusInfo.code;
}
---

<Layout
    title={`${statusInfo.code} ${statusInfo.title}`}
    description={statusInfo.description}
>
    <article class="prose dark:prose-invert">
        <p class="font-mono opacity-70">HTTP Status</p>
        <h1>{statusInfo.code}: {statusInfo.title}</h1>
        <p>{statusInfo.rangeLabel}</p>
        <p>{statusInfo.description}</p>
        <p>
            Go back to the <a href="/">homepage</a>.
        </p>
    </article>
</Layout>
