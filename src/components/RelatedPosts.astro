---
import type { CollectionEntry } from "astro:content";
import { getEntries } from "astro:content";
import Post from "./Post.astro";

interface Props {
    item: CollectionEntry<"blog" | "portfolio">;
    heading?: string;
}

const { item, heading = "Related Posts" } = Astro.props as Props;

const relatedPosts = await getEntries(item.data.related || []);
const validRelatedPosts = relatedPosts.filter(
    (post): post is CollectionEntry<"blog"> => Boolean(post),
);
---

{
    validRelatedPosts.length > 0 && (
        <section class="w-full">
            <h2 class="mb-2 text-2xl font-semibold">{heading}</h2>
            <div class="grid grid-cols-1 gap-4">
                {validRelatedPosts.map((relatedPost) => (
                    <Post post={relatedPost} />
                ))}
            </div>
        </section>
    )
}
