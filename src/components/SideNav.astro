---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";

let navlinks = {
    home: "/",
    about: "/about",
    portfolio: "/portfolio",
    blog: "/blog",
};

const sideNavPages = await getCollection("pages", ({ data }) =>
    data.sideNav,
);

const pageLinks = sideNavPages
    .map((item) => ({
        title: item.data.title,
        href: `/${item.id}`,
    }))
    .filter((item) => !Object.values(navlinks).includes(item.href));

const extraLinks: {
    title: string;
    icon?: string;
    href: string;
    pinned?: boolean;
}[] = [
    {
        title: "kino.wtf",
        icon: "🍿",
        href: "https://kino.wtf",
        pinned: true,
    },
    {
        title: "letterboxd",
        icon: "fa7-brands:letterboxd",
        href: "https://letterboxd.com/kschuyler/",
    },
    {
        title: "contact",
        icon: "lineicons:envelope-1",
        href: "mailto:kai.schuyler@gmail.com",
    },
];

const navEntries = [
    ...Object.entries(navlinks).map(([title, href]) => ({ title, href })),
    ...pageLinks,
];
const sortedExtraLinks = [...extraLinks].sort((a, b) =>
    a.pinned === b.pinned ? 0 : a.pinned ? -1 : 1,
);
---

<nav
    class="top-0 flex h-min max-h-screen w-full flex-col gap-2 text-left md:sticky md:items-end md:text-right"
>
    <div
        class="flex w-full items-center justify-between md:w-auto md:flex-col md:items-end md:justify-start md:gap-2"
    >
        <a
            href="/"
            class="m-1 block text-4xl md:text-8xl"
            aria-label="site logo"
        >
            <Icon name="wind" title="zephy.dev logo" />
        </a>

        <button
            type="button"
            class="clickable shadow-square active:shadow-square-2 aria-expanded:shadow-square-4 border px-2 py-1 font-mono font-semibold md:hidden"
            data-nav-toggle
            aria-expanded="false"
            aria-controls="mobile-nav-content"
        >
            menu
        </button>
    </div>

    <div
        id="mobile-nav-content"
        data-nav-content
        class="hidden w-full gap-2 md:flex md:flex-col md:items-end md:text-right"
    >
        <h1 class="text-xl font-bold">zephy.dev</h1>
        <h3>Kai's portfolio and blog</h3>
        <hr class="prose my-2 w-full max-w-none" />
        <div
            class="flex max-w-full flex-row flex-wrap items-center gap-2 overflow-x-auto wrap-break-word whitespace-normal md:flex-col"
        >
            {
                navEntries.map(({ title, href }, index) => (
                    <>
                        <a
                            href={href}
                            class="inline-flex w-min max-w-full items-center gap-1 font-mono font-semibold break-normal md:ml-auto"
                        >
                            <span>{title?.toLowerCase()}</span>
                        </a>
                        {index < navEntries.length - 1 && (
                            <span
                                class="text-xs opacity-60 md:hidden"
                                aria-hidden="true"
                            >
                                •
                            </span>
                        )}
                    </>
                ))
            }
        </div>
        <hr class="prose my-2 w-full max-w-none" />
        <div class="flex flex-row flex-wrap items-center gap-2 md:flex-col">
            {
                // Display extra links, with pinned ones first
                sortedExtraLinks.map((link, index) => (
                    <>
                        <span class="inline-flex w-min max-w-full items-center gap-1 font-mono font-semibold break-normal md:ml-auto">
                            <a
                                href={link.href}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex w-min max-w-full items-center gap-1 break-normal md:ml-auto"
                            >
                                {link?.icon?.match(/[a-z1-9]:[a-z\-]/) ? (
                                    <Icon name={link.icon} class="inline" />
                                ) : (
                                    <span class="inline">{link.icon}</span>
                                )}
                                <span>{link.title}</span>
                            </a>
                            {link.pinned && <span class="text-xs">📌</span>}
                        </span>
                        {index < sortedExtraLinks.length - 1 && (
                            <span
                                class="text-xs opacity-60 md:hidden"
                                aria-hidden="true"
                            >
                                •
                            </span>
                        )}
                    </>
                ))
            }
        </div>
        <hr class="prose my-2 w-full max-w-none" />
    </div>

    <script is:inline>
        const navRoot = document.currentScript?.closest("nav");
        const toggleButton = navRoot?.querySelector("[data-nav-toggle]");
        const navContent = navRoot?.querySelector("[data-nav-content]");

        const setExpanded = (expanded) => {
            if (!toggleButton || !navContent) {
                return;
            }

            toggleButton.setAttribute(
                "aria-expanded",
                expanded ? "true" : "false",
            );
            navContent.classList.toggle("hidden", !expanded);
        };

        toggleButton?.addEventListener("click", () => {
            const expanded =
                toggleButton.getAttribute("aria-expanded") === "true";
            setExpanded(!expanded);
        });

        const mq = window.matchMedia("(min-width: 768px)");
        const syncWithViewport = () => {
            if (mq.matches) {
                setExpanded(true);
            } else {
                setExpanded(false);
            }
        };

        mq.addEventListener("change", syncWithViewport);
        syncWithViewport();
    </script>
</nav>
